            "is_source": true
        },
        "HeatPump": {
            "type": "HeatPump",
            "model_type": "inverter",
            "control_modules": [
                {
                    "name": "storage_driven",
                    "low_threshold": 0.2,
                    "high_threshold": 0.95,
                    "min_run_time": 0,
                    "storage_uac": "BufferTank"
                }
            ],
            "output_refs": {
                "m_heat_out": "BUS_Heat"
            },
            "power_th": 8.5e6,
            "__OPTIONAL_MEDIA__": "",
            "m_heat_in": "m_heat_source",
            "m_el_in": "m_power",
            "m_heat_out": "m_heat",
            "__OPTIONAL_COP_AND_POWER__": "",
