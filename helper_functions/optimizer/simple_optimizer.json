{
    "io_settings": {
        "csv_output_file": "nothing",
        "auxiliary_info": false,
        "sankey_plot": "nothing",
        "output_plot": "nothing",
        "return_output_keys":  {
            "Demand_Heat":  ["Demand"],
            "Demand_Power": ["Demand"],
            "BUS_Power": ["Balance"], 
            "BUS_Heat": ["Balance"],
            "Grid_IN": ["m_power:OUT"]
        },
        "csv_output_keys": {
			"economy":  ["annuity_total", "annuity_revenue"],
            "optimizer": ["objective"]
        }
    },
    "simulation_parameters": {
        "start": "01.01.2024 00:00",
        "end": "31.12.2024 23:45",
        "start_end_unit": "dd.mm.yyyy HH:MM",
        "time_step": 900,
        "time_step_unit": "seconds",
        "epsilon": 1e-7,
        "weather_file_path": "./profiles/weather/TRY2015_Stuttgart.epw"  
    },
    "components": {
        "Grid_IN": {
            "type": "GridConnection",
            "output_refs": [
                "BUS_Power"
            ],
            "medium": "m_power",
            "is_source": true
        },
        "Heat_Source_HP": {
            "type": "GenericHeatSource",
            "output_refs": [
                "HeatPump"
            ],
            "medium": "m_heat_source",
            "temperature_from_global_file": "temp_ambient_air",
