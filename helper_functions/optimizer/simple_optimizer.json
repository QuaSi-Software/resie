            "bypass_cop": 15.0,
            "min_power_function": "const:0.0",
            "max_power_function": "poly-2: 0.001119613, -0.06349226, 0.03004031, -0.000400244, 0.002087081, -0.000351640, -0.000003101, -0.0000000655, -0.000013215, 0.000001353",
            "__OPTIONAL_LOSSES__": "",
            "heat_losses_factor": 0.95,
            "power_losses_factor": 0.97,
            "__OPTIONAL_ICING__": "",
            "consider_icing": true,
            "icing_coefficients": "3,-0.42,15,2,30"
        },
        "BUS_Power": {
            "type": "Bus",
            "medium": "m_power",
            "connections": {
                "input_order": [
                    "Grid_IN"
                ],
                "output_order": [
                    "Demand_Power",
                    "HeatPump"
                ],
                "energy_flow": [
                    [1, 1]
                ]
            }           
        },
        "BUS_Heat": {
            "type": "Bus",
            "medium": "m_heat",
            "connections": {
                "input_order": [
                    "HeatPump",
                    "BufferTank"
                ],
                "output_order": [
                    "Demand_Heat",
					"BufferTank"
                ],
                "energy_flow": [
					[1, 1],
					[1, 0]
                ]
            }
        },
        "BufferTank": {
            "type": "BufferTank",
            "output_refs": [
                "BUS_Heat"
            ],
            "medium": "m_heat",
            "___GENERAL PARAMETER___": "",
            "model_type": "ideally_stratified",
            "capacity": 65.0e6,
            "rho_medium": 1000,
            "cp_medium": 4.18,
            "high_temperature": 90.0,
            "low_temperature": 50.0,
            "initial_load": 0.5,
            "max_load_rate": 0.25,
            "max_unload_rate": 0.2,
            "___BALANCED MODEL ONLY___": "",
            "switch_point": 0.1,
            "___LOSSES___": "",
            "consider_losses": true,
            "h_to_r": 13.33,
            "ambient_temperature_from_global_file": "temp_ambient_air",
            "ground_temperature": 12,
            "thermal_transmission_lid": 1.2,
            "thermal_transmission_barrel": 1.2,
            "thermal_transmission_bottom": 1.2
        },
        "Demand_Heat": {
            "type": "Demand",
            "output_refs": [],
            "medium": "m_heat",
            "energy_profile_file_path": "th_demand",
            "constant_temperature": 90,
            "scale": 1
        },
        "Demand_Power": {
            "type": "Demand",
            "output_refs": [],
            "medium": "m_power",
            "energy_profile_file_path": "el_demand",
            "scale": 1
        }
    },
